# Professional Bank Website Configuration
# Copy this file to .env.local and update with your values

# Application Settings
APP_NAME=Professional Bank
APP_URL=http://localhost/bank-website-grok
APP_ENV=development
APP_DEBUG=true

# Contact Information
BANK_PHONE=+1 (234) 567-890
BANK_EMAIL=support@bank.com
BANK_ADDRESS=123 Banking Street, Financial City, FC 12345

# Database Configuration (if using database)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=bank_db
DB_USER=root
DB_PASS=

# Mail Configuration
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM_ADDRESS=support@bank.com
MAIL_FROM_NAME="Professional Bank"

# reCAPTCHA Configuration
RECAPTCHA_SITE_KEY=your-site-key
RECAPTCHA_SECRET_KEY=your-secret-key

# API Keys (for third-party services)
# GOOGLE_MAPS_API_KEY=your-api-key
# STRIPE_PUBLIC_KEY=your-public-key
# STRIPE_SECRET_KEY=your-secret-key

# Session Configuration
SESSION_TIMEOUT=3600
SESSION_SECURE=false
SESSION_HTTPONLY=true

# Pagination
ITEMS_PER_PAGE=10

# Time Zone
APP_TIMEZONE=Asia/Kolkata

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug

# File Uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,jpeg,png,xlsx

# Security
CSRF_PROTECTION=true
FORCE_HTTPS=false
